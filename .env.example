# Copy this file to ".env" and fill in your Supabase project values.
# Find them in: Supabase dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Cloudflare Turnstile CAPTCHA on the login form.
# Leave blank to disable. If set, also enable CAPTCHA in Supabase Auth settings
# with the matching Turnstile SECRET key. See SECURITY-SETUP.md.
VITE_TURNSTILE_SITE_KEY=
